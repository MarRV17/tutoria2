Algoritmo DosNumerosProductoCociente
	Escribir "Ingrese dos nºmeros:"
	Leer numero1, numero2
	Escribir "Producto: ", numero1 * numero2
	Si numero2 <> 0 Entonces
		Escribir "Cociente: ", numero1 / numero2
	Sino
		Escribir "Cociente: No se puede dividir por cero"
	FinSi
FinAlgoritmo

